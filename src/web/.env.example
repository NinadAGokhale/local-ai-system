# Required: User credentials. Each user needs one line.
# Pattern: SARATTHYA_<USERNAME>_PASSWORD=<value>
# Usernames are case-insensitive and derived from the env var name.

SARATTHYA_SAEE_PASSWORD=changeme
SARATTHYA_NINAD_PASSWORD=changeme
SARATTHYA_SHOUNAK_PASSWORD=changeme
SARATTHYA_SOHUM_PASSWORD=changeme

# Add more users by adding more lines:
# SARATTHYA_JANE_PASSWORD=changeme
# SARATTHYA_JOHN_PASSWORD=changeme

# Optional overrides (defaults shown below)
# SARATTHYA_REPO=NinadAGokhale/local-ai-system
# SARATTHYA_GH_PROJECT=1
# SARATTHYA_GH_OWNER=NinadAGokhale
